          },
          {
            "id": "kasra",
            "title": "齐齿符||Kasra",
            "symbol": "ـِ",
            "summary": "让辅音带短促的 i 音。||Adds a short i sound to the consonant.",
            "example": {
              "id": "kasra_bi",
              "arabicWithDiacritics": "بِ",
              "arabicPlain": "ب",
              "transliteration": "bi",
              "translation": "短音 i||short i",
              "audioPath": ""
            }
          },
          {
            "id": "damma",
            "title": "合口符||Damma",
            "symbol": "ـُ",
            "summary": "让辅音带短促的 u 音。||Adds a short u sound to the consonant.",
            "example": {
              "id": "damma_bu",
              "arabicWithDiacritics": "بُ",
              "arabicPlain": "ب",
              "transliteration": "bu",
              "translation": "短音 u||short u",
              "audioPath": ""
            }
          },
          {
            "id": "sukun",
            "title": "静音符||Sukun",
            "symbol": "ـْ",
            "summary": "表示这个辅音不再带元音。||Shows that the consonant carries no following vowel.",
