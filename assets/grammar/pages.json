              "id": "sukun_b",
              "arabicWithDiacritics": "بْ",
              "arabicPlain": "ب",
              "transliteration": "b",
              "translation": "停住||stop the sound",
              "audioPath": ""
            }
          },
          {
            "id": "shadda",
            "title": "叠音符||Shadda",
            "symbol": "ـّ",
            "summary": "表示辅音重读或双写。||Marks consonant doubling or emphasis.",
