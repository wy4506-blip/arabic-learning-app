            ["ل", "Lam", "l", "细长高频||slim and frequent"],
            ["م", "Mim", "m", "圆润主体||rounded body"],
            ["ن", "Nun", "n", "上方 1 点||1 dot above"],
            ["و", "Waw", "w / uu", "常断开||often breaks"],
            ["ي", "Ya", "y / ii", "下方 2 点||2 dots below"]
