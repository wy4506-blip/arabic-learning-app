            ["ث", "Tha", "th", "上方 3 点||3 dots above"],
            ["ج", "Jim", "j", "下方 1 点||1 dot below"],
            ["ح", "Hha", "ḥ", "无点||no dots"],
            ["خ", "Kha", "kh", "上方 1 点||1 dot above"],
