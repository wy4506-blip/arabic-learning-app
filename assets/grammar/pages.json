            ["ر", "Ra", "r", "常断开||often breaks"],
            ["س", "Sin", "s", "三齿形||three-tooth shape"],
            ["ش", "Shin", "sh", "三齿 + 3 点||three teeth + 3 dots"],
            ["ص", "Sad", "ṣ", "厚音||heavy sound"],
            ["ع", "Ayn", "ʿ", "咽音||pharyngeal"],
